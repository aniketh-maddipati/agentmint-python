#!/usr/bin/env bash
set -uo pipefail
cd "$(dirname "$0")"

if [ -t 1 ]; then
  BOLD=$(tput bold); DIM=$(tput dim); RED=$(tput setaf 1)
  GRN=$(tput setaf 2); YEL=$(tput setaf 3); RST=$(tput sgr0)
else
  BOLD=""; DIM=""; RED=""; GRN=""; YEL=""; RST=""
fi

heading() { echo; echo "${BOLD}-- $1 --${RST}"; }
ok()      { echo "  ${GRN}OK${RST} $1"; }
fail()    { echo "  ${RED}FAIL${RST} $1"; }
hint()    { echo "  ${DIM}-> $1${RST}"; }

show_help() {
  cat <<HELP
agentmint -- cryptographic receipts for AI agent actions

Usage: ./agentmint <command>

Commands:
  show      Print the receipt JSON, signature length, public key
            fingerprint, and a field-by-field walkthrough.
  verify    Verify the pre-generated receipt in sample_output/ (no Python).
  tamper    Flip a byte, watch verify fail, restore, watch it pass.
  controls  Print HIPAA + HITRUST control mappings from controls.md.
  demo      Generate a fresh receipt with run_demo.py (Python required).
  all       Run verify, tamper, demo in sequence.
  help      Show this message.

Requirements:
  verify, tamper:  openssl, jq, sha256sum (or shasum on macOS)
  demo:            Python 3.9+, pip
HELP
}

check_tools() {
  local missing=()
  command -v openssl >/dev/null 2>&1 || missing+=("openssl")
  command -v jq      >/dev/null 2>&1 || missing+=("jq")
  command -v sha256sum >/dev/null 2>&1 || command -v shasum >/dev/null 2>&1 || missing+=("sha256sum")
  if [ ${#missing[@]} -gt 0 ]; then
    fail "missing tools: ${missing[*]}"
    case "$(uname -s)" in
      Darwin) hint "macOS install: brew install ${missing[*]}" ;;
      Linux)  hint "Linux install: apt install ${missing[*]}" ;;
    esac
    return 1
  fi
  return 0
}

cmd_verify() {
  heading "Verify pre-generated receipt"
  check_tools || return 1
  if [ ! -d "sample_output" ]; then
    fail "sample_output/ not found"
    return 1
  fi

  # Show what's being verified before we verify
  local rcpt="sample_output/receipts/00001.json"
  if [ -f "$rcpt" ] && command -v jq >/dev/null 2>&1; then
    local action ts agent
    action=$(jq -r '.action' "$rcpt")
    ts=$(jq -r '.timestamp' "$rcpt")
    agent=$(jq -r '.agent_id' "$rcpt")
    echo "  Verifying receipt:"
    echo "    action:    $action"
    echo "    agent_id:  $agent"
    echo "    signed at: $ts"
    echo
  fi

  (cd sample_output && bash ../verify.sh) || { fail "verification failed"; return 1; }
  ok "all checks passed"
  hint "next: ./agentmint show (or ./agentmint tamper)"
}

cmd_tamper() {
  heading "Tamper test"
  check_tools || return 1
  local payload="sample_output/receipts/00001.json.payload"
  [ -f "$payload" ] || { fail "payload not found"; return 1; }

  cp "$payload" "${payload}.bak"
  echo "  Step 1: append one byte"
  printf 'X' >> "$payload"

  echo "  Step 2: verify (expecting failure)"
  if (cd sample_output && bash ../verify.sh >/dev/null 2>&1); then
    fail "verify still passed -- restoring"
    mv "${payload}.bak" "$payload"
    return 1
  fi
  ok "verification failed as expected"

  echo "  Step 3: restore byte"
  mv "${payload}.bak" "$payload"

  echo "  Step 4: verify (expecting success)"
  if (cd sample_output && bash ../verify.sh >/dev/null 2>&1); then
    ok "verification passes again"
  else
    fail "verify failed after restore"
    return 1
  fi
  ok "tamper test complete"
  hint "next: ./agentmint demo"
}

cmd_demo() {
  heading "Generate and verify a fresh receipt"
  if ! command -v python3 >/dev/null 2>&1; then
    fail "python3 not found"
    hint "install Python 3.9+ from python.org or your package manager"
    return 1
  fi

  # Check Python version >= 3.9 (cryptography library requires it)
  PY_VER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)
  PY_MAJOR=${PY_VER%%.*}
  PY_MINOR=${PY_VER##*.}
  if [ "$PY_MAJOR" -lt 3 ] || { [ "$PY_MAJOR" -eq 3 ] && [ "$PY_MINOR" -lt 9 ]; }; then
    fail "python3 is $PY_VER — need 3.9+"
    hint "macOS: brew install python@3.12  (then 'rm -rf .venv && ./agentmint demo')"
    hint "or use pyenv: pyenv install 3.12 && pyenv local 3.12"
    return 1
  fi
  ok "python3 $PY_VER"

  if [ ! -d ".venv" ]; then
    python3 -m venv .venv || { fail "venv creation failed"; return 1; }
  fi
  source .venv/bin/activate
  pip install -q -r requirements.txt || { fail "pip install failed"; return 1; }
  ok "deps installed"
  python run_demo.py || { fail "demo script failed"; return 1; }
  bash verify.sh || { fail "verify.sh failed"; return 1; }
  ok "fresh receipt generated and verified"
}

cmd_all() {
  cmd_verify || return 1
  cmd_tamper || return 1
  cmd_demo   || return 1
  heading "All checks complete"
  ok "verified, tampered, generated fresh"
}

cmd_show() {
  heading "What's in the pre-generated receipt"
  if [ ! -d "sample_output" ]; then
    fail "sample_output/ not found"
    return 1
  fi
  command -v jq >/dev/null 2>&1 || { fail "jq required"; return 1; }

  local rcpt="sample_output/receipts/00001.json"
  local sig="sample_output/receipts/00001.json.sig"
  local pub="sample_output/keys/public.pem"

  echo
  echo "  Receipt JSON ($rcpt):"
  echo
  jq . "$rcpt" | sed 's/^/    /'
  echo
  echo "  Signature: $(wc -c < "$sig" | tr -d " ") bytes (raw Ed25519, RFC 8032)"
  echo
  echo "  Public key fingerprint:"
  echo "    SHA-256: $(openssl pkey -pubin -in "$pub" -outform DER 2>/dev/null | shasum -a 256 | awk "{print \$1}" | head -c 32)..."
  echo
  echo "  Field walkthrough:"
  echo "    action               → what the agent did (workflow-specific string)"
  echo "    agent_id             → which agent took the action"
  echo "    payload_sha256       → hash of the action's payload (no PHI on the wire)"
  echo "    previous_receipt_hash → chain link; GENESIS for the first receipt"
  echo "    public_key_id        → which customer key signed this"
  echo "    receipt_id           → monotonic counter"
  echo "    signature_alg        → ed25519 (always)"
  echo "    subject_ref          → hashed reference to the subject (e.g., patient ID)"
  echo "    timestamp            → ISO-8601 UTC, signed in the canonical bytes"
  echo "    version              → schema version (1.0)"
  echo
  hint "next: ./agentmint verify (then ./agentmint controls)"
}

cmd_controls() {
  heading "Compliance control mappings"
  if [ ! -f "controls.md" ]; then
    fail "controls.md not found"
    return 1
  fi
  echo
  cat controls.md | sed 's/^/  /'
  echo
  hint "see README.md for context on demonstrated vs enabled scope"
}

case "${1:-help}" in
  verify)   cmd_verify   ;;
  tamper)   cmd_tamper   ;;
  demo)     cmd_demo     ;;
  show)     cmd_show     ;;
  controls) cmd_controls ;;
  all)      cmd_all      ;;
  help|-h|--help) show_help ;;
  *) fail "unknown command: $1"; show_help; exit 1 ;;
esac
