[3.770922, "o", "\u001b[54D\u001b[27mm\u001b[27mk\u001b[27md\u001b[27mi\u001b[27mr\u001b[27m \u001b[27m-\u001b[27mp\u001b[27m \u001b[27m/\u001b[27mt\u001b[27mm\u001b[27mp\u001b[27m/\u001b[27ml\u001b[27ma\u001b[27mn\u001b[27mg\u001b[27mg\u001b[27mr\u001b[27ma\u001b[27mp\u001b[27mh\u001b[27m-\u001b[27md\u001b[27me\u001b[27mm\u001b[27mo\u001b[27m \u001b[27m&\u001b[27m&\u001b[27m \u001b[27mc\u001b[27md\u001b[27m \u001b[27m/\u001b[27mt\u001b[27mm\u001b[27mp\u001b[27m/\u001b[27ml\u001b[27ma\u001b[27mn\u001b[27mg\u001b[27mg\u001b[27mr\u001b[27ma\u001b[27mp\u001b[27mh\u001b[27m-\u001b[27md\u001b[27me\u001b[27mm\u001b[27mo"]
